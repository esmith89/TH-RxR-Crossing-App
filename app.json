{
  "expo": {
    "name": "Terre Haute Train App",
    "slug": "terre-haute-train-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eric.smith9.snackdebeb22b25e3459f92c55b6d3805ab99",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Terre Haute Train App needs your location to show you the closest blocked railroad crossings.",
        "NSLocationAlwaysUsageDescription": "Terre Haute Train App needs your location to alert you of blocked crossings nearby.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-location",
      "expo-notifications",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "6d2c5684-ba5f-4da2-9cc6-1643ff734785"
      }
    }
  }
}
